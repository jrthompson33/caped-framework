---
import { getCollection } from 'astro:content';
import ExampleSection from '@/components/ExampleSection.astro';
import FrameworkLegend from '@/components/FrameworkLegend.astro';
import SidebarScrollSpy from '@/components/SidebarScrollSpy.astro';

const [paper] = await getCollection('site');
const examples = (await getCollection('examples'))
  .filter((entry) => !entry.data.draft)
  .sort((a, b) => a.data.order - b.data.order);

if (!paper) {
  throw new Error('Missing site content: src/content/site/paper.md');
}

const { title, subtitle, venue, year, authors, abstract } = paper.data;
---

<div class="caped-supplement">
  <header>
    <h1 id="_top">{title}</h1>
    <p class="subtitle">{subtitle}</p>
    <p class="authors">{authors.join(' · ')}</p>
  </header>

  <section id="about-caped" class="example-card about-section">
    <div class="example-body">
      <h2>About CAPED</h2>
      <p>{abstract}</p>
      <FrameworkLegend showDescriptions />
    </div>
  </section>

  <nav class="toc-card" aria-label="Scenario table of contents">
    <h2 class="section-label">Scenarios</h2>
    <ol>
      {
        examples.map((example) => (
          <li>
            <a href={`#${example.slug}`}>
              {example.data.order}. {example.data.title}
            </a>
          </li>
        ))
      }
    </ol>
  </nav>

  <section class="examples-stack">
    {examples.map((example) => <ExampleSection example={example} />)}
  </section>
</div>

<SidebarScrollSpy />

