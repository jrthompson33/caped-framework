---
import { capedDimensions } from '@/config/site';

interface Props {
  showDescriptions?: boolean;
}

const { showDescriptions = false } = Astro.props;
---

<aside
  class:list={['legend-card', showDescriptions && 'legend-with-descriptions']}
  aria-label="CAPED framework dimensions"
>
  <h2 class="section-label">CAPED Dimensions</h2>
  <ul class="legend-list">
    {
      capedDimensions.map((dim) => (
        <li class:list={['legend-item', `caped-legend-active-${dim.id}`]}>
          <span class="legend-item-inner">
            <span
              class="legend-badge"
              style={`background: var(--caped-${dim.id});`}
              title={dim.label}
            >
              {dim.short}
            </span>
            <span>
              <span class="legend-label" style={`color: var(--caped-${dim.id}-text);`}>
                {dim.label}
              </span>
              {showDescriptions && <span class="legend-description">{dim.description}</span>}
            </span>
          </span>
        </li>
      ))
    }
  </ul>
</aside>

<style>
  .legend-card {
    margin-top: 2rem;
  }

  .legend-list {
    display: grid;
    gap: 0.5rem;
    grid-template-columns: repeat(5, minmax(0, 1fr));
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .legend-item {
    border-radius: 0.5rem;
    padding: 0.375rem 0.5rem;
  }

  .legend-item-inner {
    align-items: flex-start;
    display: flex;
    flex-direction: column;
    font-size: 0.875rem;
    gap: 0.375rem;
  }

  .legend-badge {
    align-items: center;
    border-radius: 0.25rem;
    color: #fff;
    display: inline-flex;
    flex-shrink: 0;
    font-size: 0.75rem;
    font-weight: 700;
    height: 1.25rem;
    justify-content: center;
    width: 1.25rem;
  }

  .legend-label {
    font-weight: 600;
  }

  .legend-description {
    color: var(--sl-color-gray-3);
    display: block;
    font-size: 0.6875rem;
    line-height: 1.35;
  }
</style>
